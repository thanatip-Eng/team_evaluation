// ตรวจสอบการ login ด้วยอีเมล
function loginWithEmail(email) {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheet = ss.getSheetByName('name');
  const data = sheet.getDataRange().getValues();
  
  // หา header row
  const headers = data[0];
  const loginIdCol = headers.indexOf('login_id');
  const nameCol = headers.indexOf('name');
  const gfinalCol = headers.indexOf('gfinal');
  
  if (loginIdCol === -1 || nameCol === -1 || gfinalCol === -1) {
    return {
      success: false,
      message: 'ไม่พบ column ที่จำเป็นใน sheet (login_id, name, gfinal)'
    };
  }
  
  // หา user
  for (let i = 1; i < data.length; i++) {
    if (data[i][loginIdCol] && data[i][loginIdCol].toString().toLowerCase().trim() === email.toLowerCase().trim()) {
      return {
        success: true,
        email: email.toLowerCase().trim(),
        studentId: data[i][0], // column แรกเป็นรหัสนักศึกษา
        name: data[i][nameCol],
        group: data[i][gfinalCol],
        rowIndex: i + 1
      };
    }
  }
  
  return {
    success: false,
    message: 'ไม่พบอีเมล "' + email + '" ในระบบ กรุณาตรวจสอบอีเมลและลองใหม่'
  };
}

// ดึงรายชื่อเพื่อนในกลุ่มเดียวกัน
function getGroupMembers(userGroup, userEmail) {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const nameSheet = ss.getSheetByName('name');
  const resultSheet = ss.getSheetByName('peerresult');
  
  const nameData = nameSheet.getDataRange().getValues();
  const headers = nameData[0];
  
  const loginIdCol = headers.indexOf('login_id');
  const nameCol = headers.indexOf('name');
  const gfinalCol = headers.indexOf('gfinal');
  
  // ดึงข้อมูลผลการประเมิน
  let resultData = [];
  if (resultSheet && resultSheet.getLastRow() > 0) {
    resultData = resultSheet.getDataRange().getValues();
  }
  
  const members = [];
  
  for (let i = 1; i < nameData.length; i++) {
    const row = nameData[i];
    if (row[gfinalCol] === userGroup && 
        row[loginIdCol] && 
        row[loginIdCol].toString().toLowerCase().trim() !== userEmail.toLowerCase().trim()) {
      // ตรวจสอบว่าประเมินแล้วหรือยัง
      const evaluated = checkIfEvaluated(userEmail, row[loginIdCol].toString().trim(), resultData);
      
      members.push({
        studentId: row[0],
        name: row[nameCol],
        email: row[loginIdCol].toString().trim(),
        evaluated: evaluated
      });
    }
  }
  
  return members;
}

// ตรวจสอบว่าประเมินแล้วหรือยัง
function checkIfEvaluated(evaluatorEmail, evaluatedEmail, resultData) {
  if (!resultData || resultData.length <= 1) return false;
  
  // column A เป็น evaluator_email และ column B เป็น evaluated_email
  for (let i = 1; i < resultData.length; i++) {
    if (resultData[i][0] && resultData[i][1] && 
        resultData[i][0].toString().toLowerCase().trim() === evaluatorEmail.toLowerCase().trim() &&
        resultData[i][1].toString().toLowerCase().trim() === evaluatedEmail.toLowerCase().trim()) {
      return true;
    }
  }
  return false;
}

// บันทึกผลการประเมิน
function saveEvaluation(evaluatorInfo, evaluatedEmail, ratings, feedback) {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const nameSheet = ss.getSheetByName('name');
  let resultSheet = ss.getSheetByName('peerresult');
  
  // สร้าง sheet ถ้ายังไม่มี
  if (!resultSheet) {
    resultSheet = ss.insertSheet('peerresult');
  }
  
  // หาข้อมูลของผู้ถูกประเมิน
  const nameData = nameSheet.getDataRange().getValues();
  const headers = nameData[0];
  const loginIdCol = headers.indexOf('login_id');
  const nameCol = headers.indexOf('name');
  const gfinalCol = headers.indexOf('gfinal');
  
  let evaluatedInfo = null;
  for (let i = 1; i < nameData.length; i++) {
    if (nameData[i][loginIdCol] && 
        nameData[i][loginIdCol].toString().toLowerCase().trim() === evaluatedEmail.toLowerCase().trim()) {
      evaluatedInfo = {
        studentId: nameData[i][0],
        name: nameData[i][nameCol],
        group: nameData[i][gfinalCol]
      };
      break;
    }
  }
  
  if (!evaluatedInfo) {
    return { success: false, message: 'ไม่พบข้อมูลผู้ถูกประเมิน' };
  }
  
  // ตรวจสอบว่าประเมินซ้ำหรือไม่
  if (resultSheet.getLastRow() > 0) {
    const resultData = resultSheet.getDataRange().getValues();
    for (let i = 1; i < resultData.length; i++) {
      if (resultData[i][0] && resultData[i][1] &&
          resultData[i][0].toString().toLowerCase().trim() === evaluatorInfo.email.toLowerCase().trim() &&
          resultData[i][1].toString().toLowerCase().trim() === evaluatedEmail.toLowerCase().trim()) {
        return { success: false, message: 'คุณได้ประเมินเพื่อนคนนี้ไปแล้ว' };
      }
    }
  }
  
  // เตรียมข้อมูลที่จะบันทึก
  const row = [
    evaluatorInfo.email,           // A: evaluator_email
    evaluatedEmail,                // B: evaluated_email
    evaluatorInfo.studentId,       // C: evaluator_id
    evaluatorInfo.name,            // D: evaluator_name
    evaluatedInfo.studentId,       // E: evaluated_id
    evaluatedInfo.name,            // F: evaluated_name
    ratings.q1 || '',              // G: competency 1
    ratings.q2 || '',              // H: competency 2
    ratings.q3 || '',              // I: competency 3
    ratings.q4 || '',              // J: competency 4
    ratings.q5 || '',              // K: competency 5
    feedback.strengths || '',      // L: จุดเด่น
    feedback.improvements || '',   // M: ข้อควรปรับปรุง
    new Date()                     // N: timestamp
  ];
  
  // ถ้ายังไม่มี header ให้เพิ่ม
  if (resultSheet.getLastRow() === 0) {
    resultSheet.appendRow([
      'evaluator_email',
      'evaluated_email', 
      'evaluator_id',
      'evaluator_name',
      'evaluated_id',
      'evaluated_name',
      'comp1_planning',
      'comp2_accountability',
      'comp3_teamwork',
      'comp4_quality',
      'comp5_time_management',
      'strengths',
      'improvements',
      'timestamp'
    ]);
  }
  
  resultSheet.appendRow(row);
  
  return { success: true, message: 'บันทึกผลการประเมินเรียบร้อยแล้ว' };
}

// ดึงข้อมูลผู้ที่จะถูกประเมิน
