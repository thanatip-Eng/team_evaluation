  <script>
    let currentUser = null;
    let groupMembers = [];
    let currentEvaluatedEmail = null;
    
    // Handle login
    function handleLogin() {
      const emailInput = document.getElementById('emailInput');
      const email = emailInput.value.trim();
      const loginBtn = document.getElementById('loginBtn');
      const loginError = document.getElementById('loginError');
      
      loginError.classList.add('hidden');
      
      if (!email) {
        loginError.textContent = 'กรุณากรอกอีเมล';
        loginError.classList.remove('hidden');
        return;
      }
      
      // Validate email format
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email)) {
        loginError.textContent = 'รูปแบบอีเมลไม่ถูกต้อง';
        loginError.classList.remove('hidden');
        return;
      }
      
      loginBtn.disabled = true;
      loginBtn.textContent = 'กำลังตรวจสอบ...';
      
      google.script.run
        .withSuccessHandler(function(result) {
          if (result.success) {
            currentUser = result;
            document.getElementById('loginView').classList.add('hidden');
            displayUserInfo();
          } else {
            loginError.textContent = result.message;
            loginError.classList.remove('hidden');
            loginBtn.disabled = false;
            loginBtn.textContent = 'เข้าสู่ระบบ';
          }
        })
        .withFailureHandler(function(error) {
          loginError.textContent = 'เกิดข้อผิดพลาด: ' + error.message;
          loginError.classList.remove('hidden');
          loginBtn.disabled = false;
          loginBtn.textContent = 'เข้าสู่ระบบ';
        })
        .loginWithEmail(email);
    }
    
    // Handle Enter key on email input
    document.addEventListener('DOMContentLoaded', function() {
      const emailInput = document.getElementById('emailInput');
      if (emailInput) {
        emailInput.addEventListener('keypress', function(e) {
          if (e.key === 'Enter') {
            e.preventDefault();
            handleLogin();
          }
        });
      }
      
      const form = document.getElementById('evalForm');
      if (form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          submitEvaluation();
        });
      }
      
      const systemForm = document.getElementById('systemEvalForm');
      if (systemForm) {
        systemForm.addEventListener('submit', function(e) {
          e.preventDefault();
          submitSystemEvaluation();
        });
      }
    });
    
    function logout() {
      if (confirm('คุณต้องการออกจากระบบใช่หรือไม่?')) {
        currentUser = null;
        document.getElementById('mainView').classList.add('hidden');
        document.getElementById('membersView').classList.add('hidden');
        document.getElementById('evaluationView').classList.add('hidden');
        document.getElementById('successView').classList.add('hidden');
        document.getElementById('loginView').classList.remove('hidden');
        document.getElementById('emailInput').value = '';
        document.getElementById('loginError').classList.add('hidden');
      }
    }
    
    function displayUserInfo() {
      document.getElementById('userStudentId').textContent = currentUser.studentId;
      document.getElementById('userName').textContent = currentUser.name;
      document.getElementById('userGroup').textContent = currentUser.group;
      
      document.getElementById('loadingState').classList.add('hidden');
      document.getElementById('mainView').classList.remove('hidden');
    }
    
    function showGroupMembers() {
      document.getElementById('loadingState').classList.remove('hidden');
      document.getElementById('mainView').classList.add('hidden');
      
      google.script.run
        .withSuccessHandler(function(members) {
          groupMembers = members;
          displayGroupMembers();
        })
        .withFailureHandler(function(error) {
          showError('เกิดข้อผิดพลาด: ' + error.message);
        })
        .getGroupMembers(currentUser.group, currentUser.email);
    }
    
    function displayGroupMembers() {
      const membersList = document.getElementById('membersList');
      membersList.innerHTML = '';
      
      if (groupMembers.length === 0) {
        membersList.innerHTML = '<p style="text-align:center; color:#6c757d; padding: 40px;">ไม่พบเพื่อนในกลุ่ม</p>';
      } else {
        groupMembers.forEach(function(member) {
          const item = document.createElement('div');
          item.className = 'member-item';
          
          const statusClass = member.evaluated ? 'status-completed' : 'status-pending';
          const statusText = member.evaluated ? 'ประเมินแล้ว' : 'ยังไม่ได้ประเมิน';
          
          item.innerHTML = `
            <div class="member-info">
              <div class="member-name">${member.name}</div>
              <div class="member-id">รหัส: ${member.studentId}</div>
            </div>
            <div style="display: flex; align-items: center; gap: 10px;">
              <span class="status-badge ${statusClass}">${statusText}</span>
              ${!member.evaluated ? `<button class="btn btn-small" onclick="startEvaluation('${member.email}')">ประเมิน</button>` : ''}
            </div>
          `;
          
          membersList.appendChild(item);
        });
      }
      
      document.getElementById('loadingState').classList.add('hidden');
      document.getElementById('membersView').classList.remove('hidden');
    }
    
    function startEvaluation(evaluatedEmail) {
      currentEvaluatedEmail = evaluatedEmail;
      
      google.script.run
        .withSuccessHandler(function(info) {
          if (info) {
            document.getElementById('evaluatedName').textContent = info.name;
            document.getElementById('evaluatedId').textContent = info.studentId;
            
            document.getElementById('membersView').classList.add('hidden');
            document.getElementById('evaluationView').classList.remove('hidden');
            
            // Reset form
            document.getElementById('evalForm').reset();
            window.scrollTo(0, 0);
          }
        })
        .withFailureHandler(function(error) {
          alert('เกิดข้อผิดพลาด: ' + error.message);
        })
        .getEvaluatedInfo(evaluatedEmail);
    }
    
    function cancelEvaluation() {
      if (confirm('คุณต้องการยกเลิกการประเมินใช่หรือไม่?')) {
        document.getElementById('evaluationView').classList.add('hidden');
        document.getElementById('membersView').classList.remove('hidden');
      }
    }
    
    function submitEvaluation() {
      const form = document.getElementById('evalForm');
      const submitBtn = document.getElementById('submitBtn');
      
      // Get ratings
      const ratings = {
        q1: form.querySelector('input[name="q1"]:checked').value,
        q2: form.querySelector('input[name="q2"]:checked').value,
        q3: form.querySelector('input[name="q3"]:checked').value,
        q4: form.querySelector('input[name="q4"]:checked').value,
        q5: form.querySelector('input[name="q5"]:checked').value
      };
      
      // Get feedback
      const feedback = {
        strengths: document.getElementById('strengths').value.trim(),
        improvements: document.getElementById('improvements').value.trim()
      };
      
      // Validate
      if (!feedback.strengths || !feedback.improvements) {
        alert('กรุณากรอกข้อมูลให้ครบถ้วน');
        return;
      }
      
      // Disable submit button
      submitBtn.disabled = true;
      submitBtn.textContent = 'กำลังบันทึก...';
      
      google.script.run
        .withSuccessHandler(function(result) {
          if (result.success) {
            showSuccessView();
          } else {
            alert('เกิดข้อผิดพลาด: ' + result.message);
            submitBtn.disabled = false;
            submitBtn.textContent = '✓ ส่งแบบประเมิน';
          }
        })
        .withFailureHandler(function(error) {
          alert('เกิดข้อผิดพลาด: ' + error.message);
          submitBtn.disabled = false;
          submitBtn.textContent = '✓ ส่งแบบประเมิน';
        })
        .saveEvaluation(currentUser, currentEvaluatedEmail, ratings, feedback);
    }
    
    function showSuccessView() {
      document.getElementById('evaluationView').classList.add('hidden');
      document.getElementById('successView').classList.remove('hidden');
      
      // Update group members list and show remaining
      google.script.run
        .withSuccessHandler(function(members) {
          groupMembers = members;
          
          const remaining = members.filter(m => !m.evaluated);
          if (remaining.length > 0) {
            const remainingDiv = document.getElementById('remainingMembers');
            const remainingList = document.getElementById('remainingList');
            remainingDiv.classList.remove('hidden');
            
            remainingList.innerHTML = '';
            remaining.forEach(function(member) {
              const item = document.createElement('div');
              item.className = 'member-item';
              item.innerHTML = `
                <div class="member-info">
                  <div class="member-name">${member.name}</div>
                  <div class="member-id">รหัส: ${member.studentId}</div>
                </div>
                <button class="btn btn-small" onclick="startEvaluation('${member.email}')">ประเมิน</button>
              `;
              remainingList.appendChild(item);
            });
          }
        })
        .getGroupMembers(currentUser.group, currentUser.email);
      
      window.scrollTo(0, 0);
    }
    
    function backToMain() {
      document.getElementById('membersView').classList.add('hidden');
      document.getElementById('mainView').classList.remove('hidden');
    }
    
    function backToMembers() {
      document.getElementById('successView').classList.add('hidden');
      // Reload ข้อมูลใหม่เพื่ออัพเดทสถานะ
      refreshMembersList();
    }
    
    function refreshMembersList() {
      const refreshBtn = document.getElementById('refreshBtn');
      if (refreshBtn) {
        refreshBtn.disabled = true;
        refreshBtn.textContent = '⏳ กำลังรีเฟรช...';
      }
      
      google.script.run
        .withSuccessHandler(function(members) {
          groupMembers = members;
          displayGroupMembers();
          
          if (refreshBtn) {
            refreshBtn.disabled = false;
            refreshBtn.textContent = '🔄 รีเฟรช';
          }
        })
        .withFailureHandler(function(error) {
          alert('เกิดข้อผิดพลาดในการรีเฟรช: ' + error.message);
          if (refreshBtn) {
            refreshBtn.disabled = false;
            refreshBtn.textContent = '🔄 รีเฟรช';
          }
        })
        .getGroupMembers(currentUser.group, currentUser.email);
    }
    
    // View My Feedback
    function viewMyFeedback() {
      document.getElementById('mainView').classList.add('hidden');
      document.getElementById('loadingState').classList.remove('hidden');
      
      google.script.run
        .withSuccessHandler(function(result) {
          document.getElementById('loadingState').classList.add('hidden');
          
          if (result.success) {
            displayFeedback(result);
          } else {
            alert(result.message);
            document.getElementById('mainView').classList.remove('hidden');
          }
        })
        .withFailureHandler(function(error) {
          document.getElementById('loadingState').classList.add('hidden');
          alert('เกิดข้อผิดพลาด: ' + error.message);
          document.getElementById('mainView').classList.remove('hidden');
        })
        .getMyFeedback(currentUser.email, currentUser.group);
    }
    
    function displayFeedback(data) {
      const content = document.getElementById('feedbackContent');
      
      let html = `
        <div class="feedback-stats">
          <div class="stat-card">
            <div class="stat-value">${data.totalPeers}</div>
            <div class="stat-label">เพื่อนในกลุ่มทั้งหมด</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">${data.evaluatedCount}</div>
            <div class="stat-label">คนที่ประเมินคุณแล้ว</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">${((parseFloat(data.averages.comp1) + parseFloat(data.averages.comp2) + parseFloat(data.averages.comp3) + parseFloat(data.averages.comp4) + parseFloat(data.averages.comp5)) / 5).toFixed(2)}</div>
            <div class="stat-label">คะแนนเฉลี่ยรวม</div>
          </div>
        </div>
        
        <div class="form-section">
          <h3>📊 สรุปคำแนะนำเพื่อการพัฒนาตนเอง</h3>
          <div class="dev-table-wrapper">
            <table class="dev-table">
              <thead>
                <tr>
                  <th>ด้านที่ประเมิน</th>
                  <th style="text-align: center; min-width: 100px;">คะแนนเฉลี่ย</th>
                  <th>คำแนะนำเพื่อพัฒนา</th>
                </tr>
              </thead>
              <tbody>
      `;
      
      // สร้างแถวในตาราง
      if (data.summary && data.summary.tableData && Array.isArray(data.summary.tableData)) {
        data.summary.tableData.forEach(function(row, index) {
          const score = parseFloat(row.score);
          let scoreClass = '';
          if (score >= 4.5) scoreClass = 'score-excellent';
          else if (score >= 4.0) scoreClass = 'score-good';
          else if (score >= 3.0) scoreClass = 'score-fair';
          else scoreClass = 'score-poor';
          
          const isOverall = index === data.summary.tableData.length - 1;
          const rowClass = isOverall ? 'overall-row' : '';
          
          html += `
            <tr class="${rowClass}">
              <td class="aspect-name">${row.name}</td>
              <td class="score-cell ${scoreClass}">${row.score}/5</td>
              <td class="suggestion-cell">${row.suggestion}</td>
            </tr>
          `;
        });
      }
      
      html += `
              </tbody>
            </table>
          </div>
        </div>
      `;
      
      // Strengths feedback
      if (data.strengths && data.strengths.length > 0) {
        html += `
          <div class="form-section">
            <h3>💪 จุดเด่นที่เพื่อนมองเห็น</h3>
            <div class="feedback-box">
        `;
        data.strengths.forEach(function(item, index) {
          html += `<div class="feedback-item">${index + 1}. ${item}</div>`;
        });
        html += `</div></div>`;
      }
      
      // Improvements feedback
      if (data.improvements && data.improvements.length > 0) {
        html += `
          <div class="form-section">
            <h3>🎯 ข้อเสนอแนะเพื่อการพัฒนา</h3>
            <div class="feedback-box">
        `;
        data.improvements.forEach(function(item, index) {
          html += `<div class="feedback-item">${index + 1}. ${item}</div>`;
        });
        html += `</div></div>`;
      }
      
      content.innerHTML = html;
      document.getElementById('feedbackView').classList.remove('hidden');
    }
    
    function backToMainFromFeedback() {
      document.getElementById('feedbackView').classList.add('hidden');
      document.getElementById('mainView').classList.remove('hidden');
    }
    
    // System Evaluation
    function showSystemEval() {
      document.getElementById('mainView').classList.add('hidden');
      document.getElementById('systemEvalView').classList.remove('hidden');
      document.getElementById('systemEvalForm').reset();
      window.scrollTo(0, 0);
    }
    
    function submitSystemEvaluation() {
      const form = document.getElementById('systemEvalForm');
      const submitBtn = document.getElementById('systemSubmitBtn');
      
      const ratings = {
        easeOfUse: form.querySelector('input[name="easeOfUse"]:checked').value,
        usefulness: form.querySelector('input[name="usefulness"]:checked').value,
        design: form.querySelector('input[name="design"]:checked').value,
        overall: form.querySelector('input[name="overall"]:checked').value
      };
      
      const feedback = {
        likedMost: document.getElementById('likedMost').value.trim(),
        suggestions: document.getElementById('suggestions').value.trim(),
        recommend: form.querySelector('input[name="recommend"]:checked').value
      };
      
      if (!feedback.likedMost) {
        alert('กรุณากรอกสิ่งที่คุณชอบที่สุด');
        return;
      }
      
      submitBtn.disabled = true;
      submitBtn.textContent = 'กำลังบันทึก...';
      
      google.script.run
        .withSuccessHandler(function(result) {
          if (result.success) {
            document.getElementById('systemEvalView').classList.add('hidden');
            document.getElementById('systemSuccessView').classList.remove('hidden');
            window.scrollTo(0, 0);
          } else {
            alert('เกิดข้อผิดพลาด: ' + result.message);
            submitBtn.disabled = false;
            submitBtn.textContent = '✓ ส่งการประเมิน';
          }
        })
        .withFailureHandler(function(error) {
          alert('เกิดข้อผิดพลาด: ' + error.message);
          submitBtn.disabled = false;
          submitBtn.textContent = '✓ ส่งการประเมิน';
        })
        .saveSystemEvaluation(currentUser, ratings, feedback);
    }
    
    function backToMainFromSystemEval() {
      document.getElementById('systemEvalView').classList.add('hidden');
      document.getElementById('mainView').classList.remove('hidden');
    }
    
    function backToMainFromSystemSuccess() {
      document.getElementById('systemSuccessView').classList.add('hidden');
      document.getElementById('mainView').classList.remove('hidden');
    }
    
    function showError(message) {
      document.getElementById('loadingState').classList.add('hidden');
      const errorDiv = document.getElementById('errorState');
      errorDiv.textContent = message;
      errorDiv.classList.remove('hidden');
    }
  </script>
</body>
</html>
